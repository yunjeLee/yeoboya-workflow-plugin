{
  "name": "yeoboya-workflow",
  "version": "2.4.3",
  "description": "앱팀 공통 개발 워크플로우 플러그인 (Android / iOS)",
  "author": {
    "name": "yeoboya"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/warn-plugin-edit.sh" }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/block-harness-commit.sh" }
        ]
      }
    ]
  }
}
